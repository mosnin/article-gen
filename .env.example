# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Price IDs for the subscription plans (required for checkout/trial)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TRIAL_PRICE_ID=price_...

# WordPress credential encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WP_ENCRYPTION_KEY=64-character-hex-string-here

# Scheduled publishing cron secret (any random string)
CRON_SECRET=your-random-cron-secret

# Google Search Console OAuth (for keyword import feature)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App base URL (used by cron route)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Modal (agent harness host) — public trigger URL printed by `modal deploy`
MODAL_AGENT_TRIGGER_URL=https://your-org--article-sauce-agents-trigger.modal.run
# Public cancel URL printed by `modal deploy` (used to abort a running job)
MODAL_AGENT_CANCEL_URL=https://your-org--article-sauce-agents-cancel.modal.run
# HMAC shared secret used to sign requests to the Modal trigger URL
MODAL_AGENT_TOKEN=replace-with-64-char-random-hex

# Webhook callback secret (Modal → Next.js /api/agent/webhook)
AGENT_WEBHOOK_SECRET=replace-with-64-char-random-hex

# Internal API secret (Modal → Next.js /api/internal/*)
AGENT_INTERNAL_SECRET=replace-with-64-char-random-hex

# Upstash Vector (agent semantic memory / dedup)
UPSTASH_VECTOR_REST_URL=https://your-index.upstash.io
UPSTASH_VECTOR_REST_TOKEN=replace-with-upstash-vector-token

# Exa (SERP + niche research; server-side + Modal)
EXA_API_KEY=replace-with-exa-api-key

# NOTE: The Modal side of the stack reads the same secrets from a Modal secret
# bundle named `article-sauce-agents` — see agents/README.md and
# docs/project/09_agentic_generation.md §11 for the full key list and the
# `modal secret create` command.

# Wasabi object storage (user + agent file uploads)
# Create a bucket and an access key pair in the Wasabi console.
WASABI_ACCESS_KEY_ID=your-wasabi-access-key
WASABI_SECRET_ACCESS_KEY=your-wasabi-secret-key
WASABI_BUCKET=your-bucket-name
WASABI_REGION=us-east-1
# Optional — defaults to https://s3.<region>.wasabisys.com
WASABI_ENDPOINT=

# Operational alerts (optional)
# Slack incoming webhook for operational alerts (stuck agent runs, etc.)
# Optional — if unset, alerts log to console only.
SLACK_ALERTS_WEBHOOK_URL=
